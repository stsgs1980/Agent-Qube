+  'flex-row', 'flex-col', 'flex-wrap', 'flex-nowrap', 'flex-1', 'flex-auto',
+  'flex-shrink-0', 'flex-shrink', 'flex-grow', 'flex-none',
+  'w-full', 'w-auto', 'h-full', 'h-auto',
+  // spacing (too common to be identifying)
+  'relative', 'absolute', 'fixed', 'static', 'sticky',
+  'overflow-hidden', 'overflow-auto', 'overflow-visible', 'overflow-scroll',
+  'overflow-x-auto', 'overflow-y-auto', 'overflow-x-hidden', 'overflow-y-hidden',
+  // typography defaults
+  'font-sans', 'font-mono', 'font-serif',
+  'font-thin', 'font-light', 'font-normal', 'font-medium', 'font-semibold', 'font-bold', 'font-extrabold',
+  'text-left', 'text-center', 'text-right', 'text-justify',
+  'text-xs', 'text-sm', 'text-base', 'text-lg', 'text-xl', 'text-2xl', 'text-3xl',
+  'uppercase', 'lowercase', 'capitalize', 'normal-case',
+  'truncate', 'break-all', 'break-words', 'break-normal',
+  'whitespace-nowrap', 'whitespace-pre', 'whitespace-normal',
+  // rounded defaults
+  'rounded', 'rounded-sm', 'rounded-md', 'rounded-lg', 'rounded-xl', 'rounded-full',
+  // transitions / cursor / select
+  'transition', 'transition-all', 'transition-colors', 'transition-opacity',
+  'duration-200', 'duration-300', 'duration-500',
+  'cursor-pointer', 'cursor-default', 'cursor-not-allowed',
+  'select-none', 'select-text', 'select-all',
+  // commonly stacked
+  'min-w-0', 'max-w-full',
+]);
+
+function pickKeyClass(classesStr: string): string {
+  if (!classesStr) return '';
+  const classes = classesStr.split(/\s+/).filter(Boolean);
+  for (const c of classes) {
+    if (GENERIC_CLASSES.has(c)) continue;
+    // Prefer classes with arbitrary values (text-[10px], w-[220px], text-[#06B6D4])
+    if (c.includes('[')) return c;
+    // Or classes with hex colors
+    if (c.includes('#')) return c;
+    // Or "non-standard" named classes (not in generic list, has dash + word)
+    if (c.length > 3 && !/^(p|m)(t|b|l|r|x|y)?-\d+$/.test(c) && !/^(gap|space)-(x|y)?-\d+$/.test(c)) {
+      // Skip pure numeric padding/margin like p-4, m-2, gap-3
+      if (/^(p|m)(t|b|l|r|x|y)?-\d+(\.\d+)?$/.test(c)) continue;
+      if (/^gap-(x|y)?-\d+$/.test(c)) continue;
+      if (/^space-(x|y)?-\d+$/.test(c)) continue;
+      if (/^w-\d+$/.test(c)) continue;
+      if (/^h-\d+$/.test(c)) continue;
+      return c;
+    }
+  }
+  return '';
+}
+
+function extractTexts(el: HTMLElement): string[] {
+  const texts: string[] = [];
+  const walk = (node: Node) => {
+    if (node.nodeType === Node.TEXT_NODE) {
+      const t = (node.textContent || '').trim();
+      if (t && t.length < 200) texts.push(t);
+    } else if (node.nodeType === Node.ELEMENT_NODE) {
+      const e = node as HTMLElement;
+      // Skip script/style/svg
+      const tag = e.tagName.toLowerCase();
+      if (['script', 'style', 'svg', 'path', 'defs', 'lineargradient', 'stop', 'polyline', 'rect', 'circle'].includes(tag)) return;
+      if (e.childNodes.length === 0) {
+        const t = (e.textContent || '').trim();
+        if (t && t.length < 200) texts.push(t);
+      } else {
+        for (const child of Array.from(e.childNodes)) walk(child);
+      }
+    }
+  };
+  walk(el);
+  // Dedupe and limit
+  return Array.from(new Set(texts)).slice(0, 6);
+}
 
