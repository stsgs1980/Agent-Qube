{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@stsgs/ui": ["packages/ui/src"],
      "@stsgs/ui/tokens": ["packages/ui/src/tokens"],
      "@stsgs/ui/hooks": ["packages/ui/src/hooks"],
      "@stsgs/ui/providers": ["packages/ui/src/providers"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
