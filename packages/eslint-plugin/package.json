{
  "name": "eslint-plugin-stsgs",
  "version": "0.1.0",
  "description": "ESLint plugin for @stsgs/ui anti-monolith rules enforcement",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "eslint": "^9.0.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "keywords": ["eslint", "eslintplugin", "stsgs", "anti-monolith"],
  "license": "MIT"
}
